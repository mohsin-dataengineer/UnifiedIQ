# =============================================================================
# UnifiedIQ UI - environment configuration
# Copy to .env.local for local dev. Validated by src/lib/env.ts (zod).
# =============================================================================

# --- Backend (BFF target; browser never calls this directly) ---
API_BASE_URL=http://localhost:5000

# --- NextAuth ---
NEXTAUTH_SECRET=replace-with-a-32-char-min-random-string
NEXTAUTH_URL=http://localhost:3000

# --- Okta OIDC ---
OIDC_ISSUER=https://example.okta.com/oauth2/default
OIDC_CLIENT_ID=replace-me
OIDC_CLIENT_SECRET=replace-me

# Local-only escape hatch: when true, the proxy allows unauthenticated calls.
AUTH_BYPASS=false

# --- Public (client-exposed) ---
NEXT_PUBLIC_APP_NAME=UnifiedIQ

# Build-only: set to "1" in CI `next build` to skip env validation when
# secrets are absent. Never set this at runtime.
# SKIP_ENV_VALIDATION=1
