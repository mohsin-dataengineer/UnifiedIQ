# =============================================================================
# UnifiedIQ API - environment configuration
# Copy to .env for local dev. Every variable read by app/config.py lives here.
# =============================================================================

# --- App ---
APP_NAME=UnifiedIQ
APP_ENV=local                      # local | staging | prod
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
# Comma-separated browser origins allowed by CORS (the UI dev origin).
CORS_ORIGINS=http://localhost:3000
# Surfaced verbatim by /api/health; set by CI/Docker build arg in real deploys.
GIT_SHA=dev

# --- LLM (Databricks Foundation Model API, OpenAI-compatible) ---
# Base URL form: https://<workspace-host>/serving-endpoints
LLM_BASE_URL=https://example.cloud.databricks.com/serving-endpoints
LLM_API_KEY=dapi-replace-me
LLM_DEFAULT_MODEL=databricks-claude-sonnet-4
LLM_EMBEDDING_MODEL=databricks-bge-large-en
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# --- Warehouse (Databricks SQL) ---
WAREHOUSE_SERVER_HOSTNAME=example.cloud.databricks.com
WAREHOUSE_HTTP_PATH=/sql/1.0/warehouses/replace-me
WAREHOUSE_ACCESS_TOKEN=dapi-replace-me
WAREHOUSE_CATALOG=main
WAREHOUSE_SCHEMA=analytics
WAREHOUSE_QUERY_TIMEOUT_SECONDS=30

# --- Vector store (Databricks Vector Search) ---
VECTOR_SEARCH_ENDPOINT=unifiediq-vs-endpoint
VECTOR_SEARCH_INDEX=main.analytics.kb_docs_index
VECTOR_SEARCH_TOP_K=5

# --- User auth (Okta OIDC - validates incoming Bearer) ---
OIDC_ISSUER=https://example.okta.com/oauth2/default
OIDC_AUDIENCE=api://unifiediq
OIDC_JWKS_TTL_SECONDS=3600
# Comma-separated Okta groups permitted to use the app. Empty = any authenticated user.
OIDC_ALLOWED_GROUPS=
# Local-only escape hatch: when true, auth is bypassed (never enable in prod).
AUTH_BYPASS=false
# oidc = validate Okta bearer (default).
# databricks = trust X-Forwarded-Email / X-Forwarded-Preferred-Username set by
# Databricks Apps SSO (use this when deployed as a Databricks App).
AUTH_MODE=oidc

# --- Service auth (machine principal for durable writes) ---
SERVICE_PRINCIPAL_ID=unifiediq-svc
SERVICE_PRINCIPAL_TOKEN=replace-me

# --- Cache ---
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1024

# --- Telemetry & session persistence (async queue workers) ---
WORKER_FLUSH_MAX_ITEMS=50
WORKER_FLUSH_INTERVAL_SECONDS=5

# --- Alerts (natural-language monitors) ---
ALERTS_ENABLED=true
# Empty -> <WAREHOUSE_CATALOG>.<WAREHOUSE_SCHEMA>.unifiediq_alerts
ALERTS_TABLE=
ALERTS_POLL_INTERVAL_SECONDS=300
ALERTS_IN_APP_MAX=100

# --- Optional Postgres (app-side telemetry/session/user-views store) ---
# Leave blank to use the in-memory dev fallback.
DATABASE_URL=postgresql://unifiediq:unifiediq@db:5432/unifiediq

# --- Integrations: Slack ---
# Bot token (xoxb-...). Leave blank to disable the Slack integration.
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#general
SLACK_API_BASE=https://slack.com/api

# --- Integrations: Email (SMTP) ---
# Leave SMTP_HOST blank to disable the email integration.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=unifiediq@example.com
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
